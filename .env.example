# ============================================================================
# WatchWithMi Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it's already in .gitignore)
# ============================================================================

# ============================================================================
# Backend Environment Variables (Server-side only - SECURE)
# ============================================================================

# YouTube API Key
# Get yours from: https://console.cloud.google.com/
# See OPTIONAL_DEPENDENCIES.md for step-by-step setup guide
YOUTUBE_API_KEY=your_youtube_api_key_here

# Application Settings (optional)
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database (if you add one later)
# DATABASE_URL=postgresql://user:password@localhost/watchwithmi

# Redis (if you use it)
# REDIS_URL=redis://localhost:6379

# Secret keys for authentication (if you add auth later)
# SECRET_KEY=your_secret_key_here
# JWT_SECRET=your_jwt_secret_here

# ============================================================================
# Frontend Environment Variables (Client-side - PUBLIC)
# ============================================================================

# Backend API URL - This is safe to expose, it's just the API endpoint
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# App Configuration (optional)
# NEXT_PUBLIC_APP_NAME=WatchWithMi
# NEXT_PUBLIC_MAX_ROOM_SIZE=10
